---
const DOWNLOAD_URL = 'https://github.com/ArekkMirmun/GeneradorExamenesEvau/releases/latest';
---

<section class="relative overflow-hidden pt-20 pb-28 sm:pt-28 sm:pb-36 bg-gradient-to-b from-teal-50/60 to-white">
  <!-- Decorative grid -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#e5e7eb22_1px,transparent_1px),linear-gradient(to_bottom,#e5e7eb22_1px,transparent_1px)] bg-[size:4rem_4rem]"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900 leading-tight">
      Generador de Exámenes
      <span class="block text-teal-600">Selectividad</span>
    </h1>

    <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
      Genera exámenes de práctica de Selectividad de Matemáticas, Física y Química con ejercicios oficiales de Andalucía. Estructura real, PDF listo para imprimir.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={DOWNLOAD_URL}
        class="inline-flex items-center gap-2 bg-teal-600 hover:bg-teal-700 text-white font-semibold text-lg px-8 py-4 rounded-xl transition-all hover:shadow-xl hover:shadow-teal-600/25 hover:-translate-y-0.5"
      >
        <span>⬇</span> Descargar GeneradorExamenes.zip
      </a>
      <a
        href="#como-funciona"
        class="inline-flex items-center gap-1 text-gray-600 hover:text-teal-700 font-medium transition-colors"
      >
        Cómo funciona →
      </a>
    </div>

    <!-- Trust badges -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-gray-500">
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
        1586 ejercicios
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
        4 asignaturas
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
        Convocatorias 2018–2025
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
        Andalucía EvAU/EBAU
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
        Solo Windows
      </span>
    </div>
  </div>
</section>
