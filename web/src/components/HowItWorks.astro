---
const DOWNLOAD_URL = 'https://github.com/ArekkMirmun/GeneradorExamenesEvau/releases/latest';

const steps = [
  {
    number: '1',
    title: 'Descarga el ZIP',
    description: 'Descarga el archivo desde la última release de GitHub. Es un ZIP ligero que no requiere instalación.',
  },
  {
    number: '2',
    title: 'Descomprime y ejecuta',
    description: 'Extrae el contenido y ejecuta GeneradorExamenes_Publica.exe. No necesitas instalar nada más.',
  },
  {
    number: '3',
    title: 'Genera tu examen',
    description: 'Selecciona la asignatura, filtra por temas y pulsa el botón. Tu examen en PDF se abrirá automáticamente.',
  },
];
---

<section id="como-funciona" class="py-24 sm:py-32 bg-gray-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Cómo funciona</h2>
      <p class="mt-4 text-gray-600 text-lg">Tres pasos. Sin instaladores, sin registro, sin complicaciones.</p>
    </div>

    <div class="space-y-8">
      {steps.map((step, i) => (
        <div class="flex gap-6 items-start">
          <!-- Step number -->
          <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-teal-600 text-white flex items-center justify-center text-xl font-bold shadow-lg shadow-teal-600/20">
            {step.number}
          </div>

          <div class="pt-1">
            <h3 class="text-lg font-semibold text-gray-900">{step.title}</h3>
            <p class="mt-1 text-gray-600">{step.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a
        href={DOWNLOAD_URL}
        class="inline-flex items-center gap-2 bg-teal-600 hover:bg-teal-700 text-white font-semibold px-8 py-4 rounded-xl transition-all hover:shadow-xl hover:shadow-teal-600/25 hover:-translate-y-0.5"
      >
        <span>⬇</span> Descargar ahora
      </a>
    </div>
  </div>
</section>
